# ============================================
# Environment Variables for Hostinger Deployment
# The Metrics - Professional Recruitment Platform
# ============================================
# Copy this file to .env on your Hostinger VPS and fill in your values.
# ============================================

# Server
NODE_ENV=production
PORT=5000

# Database (Neon PostgreSQL — your remote DB, no local install needed)
DATABASE_URL=your_neon_database_url_here

# Session Secret (generate a strong random string — e.g. openssl rand -base64 64)
SESSION_SECRET=your_session_secret_here

# Admin Credentials
ADMIN_EMAIL=info@portermetricscareeronboarding.com
ADMIN_PASSWORD=your_admin_password_here

# SMTP — Default (Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@portermetricscareeronboarding.com
SMTP_PASSWORD=your_smtp_password_here

# SMTP — Multi-company accounts (passwords only; host/user configured in admin dashboard)
ANTAVO_SMTP_PASSWORD=your_antavo_smtp_password_here
JONATHAN_SMTP_PASSWORD=your_jonathan_smtp_password_here
SEARCHBLOOM_SMTP_PASSWORD=your_searchbloom_smtp_password_here

# Stripe (Employment Hub payments)
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# OpenAI (AI features — chatbot, email reply generator)
# On Replit this uses built-in AI integrations; on Hostinger you need your own OpenAI key
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key_here
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Web Push Notifications (VAPID Keys — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# Smartsupp Live Chat (public key, safe to share)
VITE_SMARTSUPP_KEY=bc079584198e632cf069f3da44ce52d5dcb2357f

# Backup Service
BACKUP_API_KEY=your_backup_api_key_here
